# ════════════════════════════════════════════════════════════
# Delhi Governance Intelligence Platform
# Environment Configuration Template
# ════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
# The system operates in MOCK MODE for any service whose
# credentials are left empty. No real API keys required.
# ════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=delhi-governance-platform
APP_VERSION=2.0.0

# ── Backend ──────────────────────────────────────────────────
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_APP_NAME=Delhi Governance Intelligence Platform

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:password123@localhost:27017/grievance_db?authSource=admin
MONGODB_DB_NAME=grievance_db

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_123

# ── MinIO (S3-compatible Storage) ────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=miniosecret123
MINIO_BUCKET=grievance-uploads
MINIO_USE_SSL=false

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── OTP ──────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_MINUTES=15

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ══════════════════════════════════════════════════════════════
# EXTERNAL INTEGRATIONS (leave empty for mock mode)
# ══════════════════════════════════════════════════════════════

# ── WhatsApp Cloud API (Meta Business) ───────────────────────
# Get these from https://developers.facebook.com/apps/
# If empty, the system operates in mock mode and logs
# all WhatsApp messages to the console.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=delhi-cm-verify-token
WHATSAPP_API_VERSION=v18.0

# ── SMS Gateway ──────────────────────────────────────────────
# Supported: twilio, msg91, mock
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_API_KEY=
SMS_SENDER_ID=DELHICM

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@delhicm.gov.in

# ── Cloud Storage (AWS S3) ───────────────────────────────────
# If empty, MinIO local storage is used instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1

# ══════════════════════════════════════════════════════════════
# AGENTIC AI LAYER
# ══════════════════════════════════════════════════════════════
# The platform includes 6 AI agents. By default, all agents
# use MockProvider (deterministic, no API key needed).
# Set AI_PROVIDER to "openai", "gemini", or "groq" and
# provide the corresponding API key for real LLM integration.
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────
# Options: mock | openai | gemini | groq
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Agent Feature Flags ──────────────────────────────────────
# Set to false to disable individual agents
ENABLE_VISION_AGENT=true
ENABLE_DUPLICATE_AGENT=true
ENABLE_PRIORITY_AGENT=true
ENABLE_ROUTING_AGENT=true
ENABLE_VERIFICATION_AGENT=true
ENABLE_CM_ADVISOR=true

# ── Sentry (Error Tracking) ─────────────────────────────────
SENTRY_DSN=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=dev
